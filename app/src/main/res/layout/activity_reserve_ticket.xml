<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/imgBackgroundPoster"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:src="@drawable/movie1"
        android:contentDescription="영화 포스터 배경"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#77000000"
        app:layout_constraintTop_toTopOf="@id/imgBackgroundPoster"
        app:layout_constraintBottom_toBottomOf="@id/imgBackgroundPoster"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_back"
        android:contentDescription="뒤로가기"
        android:scaleType="fitCenter"
        android:padding="6dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_close"
        android:contentDescription="닫기"
        android:scaleType="fitCenter"
        android:padding="6dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/movieDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="@id/imgBackgroundPoster"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txtMovieTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="주토피아 2"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/imgAgeLimit"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_age_all"
                android:contentDescription="연령 등급"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/btnDetail"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_go"
                android:contentDescription="상세 정보" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtShowtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="2025.12.12 (금) 10:00 ~ 11:48"
            android:textColor="#CCCCCC"
            android:textSize="16sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/reservationContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/rounded_top_white_bg"
        android:clipToOutline="true"

        android:layout_marginTop="-12dp"
        android:paddingTop="20dp"

        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgBackgroundPoster"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="4dp"
        android:clipToPadding="false" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="인원 선택"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최대 8명까지 선택 가능합니다."
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ticketTypeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/ticket_type_selector" android:id="@+id/selectorAdult"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />

                <include layout="@layout/ticket_type_selector" android:id="@+id/selectorYouth"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />

                <include layout="@layout/ticket_type_selector" android:id="@+id/selectorPreferential"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />

                <include layout="@layout/ticket_type_selector" android:id="@+id/selectorSenior"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSeatSelection"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="좌석 선택"
                style="@style/RedButtonStyle"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>