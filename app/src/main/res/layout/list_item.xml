<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:padding="8dp">

    <!-- 포스터 + 하트 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/posterContainer"
        android:layout_width="95dp"
        android:layout_height="130dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/image_rounded"
        android:clipToOutline="true" >

        <ImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:src="@drawable/movie1"
            android:contentDescription="poster" />

        <View
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/black_gradient"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 하트버튼 -->
        <ImageButton
            android:id="@+id/like"
            style="@style/IconButtonStyle"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:padding="5dp"
            android:background="@drawable/heart_bg"
            android:src="@drawable/ic_heart_unfilled"
            android:layout_margin="8dp"
            android:scaleType="centerInside"
            android:contentDescription="좋아요"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 제목 -->
    <TextView
        android:id="@+id/title"
        style="@style/MovieTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="주토피아 2"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/posterContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ageLimit"/>

    <!-- 나이 등급 -->
    <ImageView
        android:id="@+id/ageLimit"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_age_all"
        android:contentDescription="age badge"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/title"/>

    <!-- 평점 -->
    <TextView
        android:id="@+id/rating"
        style="@style/MovieRatingText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="⭐ 4.5"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toEndOf="@id/posterContainer"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintEnd_toStartOf="@id/reserve"/>

    <!-- 예매하기 -->
    <Button
        android:id="@+id/reserve"
        style="@style/RedButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center"
        android:text="예매하기"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>