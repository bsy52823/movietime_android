<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ReserveCompleteActivity">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:background="#FAFAFA"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginLeft="20dp"
            android:layout_marginBottom="10dp">

            <!-- 로고 -->
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:adjustViewBounds="true"
                android:contentDescription="앱 로고"
                android:src="@drawable/logo"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOVIE TIME"
                android:textColor="@color/red"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="예매가 완료되었습니다!"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingStart="30dp"
            android:paddingEnd="24dp"
            android:gravity="start"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomButtonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgCompletePoster"
                        android:layout_width="100dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/movie1"
                        android:contentDescription="영화 포스터"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/txtCompleteMovieTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="주토피아 2"
                                android:textColor="@color/black"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginEnd="8dp"/>

                            <ImageView
                                android:id="@+id/imgCompleteAgeLimit"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="연령 제한"
                                android:scaleType="fitCenter"
                                tools:src="@drawable/ic_age_all"
                                android:layout_gravity="center_vertical"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/txtCompleteMovieDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="상영관 정보 또는 연령가 텍스트"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/txtCompleteDateTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="2025.12.12(금) 10:00 ~ 11:48"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/txtCompletePeopleSeats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="성인 1명, 청소년 1명 | D5, D6"
                            android:textColor="#888888"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/txtCompleteTotalPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="총 24,000원 결제"
                            android:textColor="#888888"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="예매 번호 ABC1234567"
                android:textColor="#666666"
                android:textSize="14sp"
                android:gravity="center_horizontal"
                android:layout_marginTop="20dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomButtonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnGoHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_home_black"
            android:layout_margin="8dp"
            android:scaleType="centerInside"
            android:contentDescription="홈으로 가기" />

        <Button
            android:id="@+id/btnCheckReservation"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="예매내역 확인"
            style="@style/RedButtonStyle"
            tools:ignore="HardcodedText" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>